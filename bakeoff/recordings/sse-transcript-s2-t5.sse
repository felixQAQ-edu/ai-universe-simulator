data:{"turn":5,"status":"ongoing","hp":80,"san":85,"discoveredRules":[{"id":7,"content":"7. 收银台抽屉里有一张白色卡片，如果感到恐惧，可以握在手里。"}],"availableActions":[{"id":"A","text":"将卡片放回内袋，回到收银台后警惕观察"},{"id":"B","text":"走向冷柜区，查看那瓶发光的蓝色饮料"},{"id":"C","text":"盯着监控屏幕，等待那个叹气声的来源出现"},{"id":"D","text":"检查店门是否仍然锁好，留意窗外动静"}]}

