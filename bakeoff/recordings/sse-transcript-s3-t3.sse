data:{"turn":3,"status":"ongoing","hp":78,"san":65,"discoveredRules":[{"id":3,"content":"3. 冰柜里的蓝色饮料永远不要卖。如果顾客指定要买，告诉他缺货。"}],"availableActions":[{"id":"A","text":"立刻将饮料放回冰柜，关好柜门"},{"id":"B","text":"握紧饮料，朝笑声来源方向走去"},{"id":"C","text":"退回收银台，拿出白色卡片握在手中"},{"id":"D","text":"对着货架方向大声询问‘谁在那里？’"}]}

