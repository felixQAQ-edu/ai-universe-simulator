data:{"turn":7,"status":"ended","hp":80,"san":0,"discoveredRules":[{"id":1,"content":"凌晨3:00至3:05期间，请务必面朝墙壁站立，不要转身，不要看走廊尽头。"},{"id":5,"content":"不要在走廊里奔跑，只能快步走。"},{"id":6,"content":"如果看到穿红色衣服的小孩，请给他一颗糖。"},{"id":7,"content":"每经过一个病房门口，必须默念“平安”。"}],"availableActions":[{"id":"A","text":"猛地掀开被子跳下床，冲向门口","hpCost":-20,"sanCost":0},{"id":"B","text":"僵硬地转过身，面对背后的东西","hpCost":-30,"sanCost":0},{"id":"C","text":"闭上眼睛，用尽全力大喊“滚开”","hpCost":-10,"sanCost":0},{"id":"D","text":"伸手摸索手机，试图打开录音或录像","hpCost":0,"sanCost":0}]}

